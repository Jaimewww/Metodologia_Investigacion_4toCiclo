	volume = {2017-May},
	pages = {48 - 59},
	url = {https://www.scopus.com/pages/publications/85019706223?origin=resultslist},
	abstract = {Simulation-based design optimization (SBDO) methods integrate computer simulations, design modification tools, and optimization algorithms. In hydrodynamic applications, often objective functions are computationally expensive and likely noisy, their derivatives are not directly provided, and the existence of local minima cannot be excluded a priori, which motivates the use of derivative-free global optimization algorithms. This type of algorithms (such as Particle Swarm Optimization, PSO) usually follow a stochastic formulation, requiring computationally expensive numerical experiments in order to provide statistically significant results. The objective of the present work is to investigate the effects of using (versus suppressing) random coefficients in PSO for ship hydrodynamics SBDO. A comparison is shown of 1,000 random PSO to deterministic PSO (DPSO) using 12 well-known scalable test problems, with dimensionality ranging from two to fifty. A total of 588 test functions is considered and more than 500,000 optimization runs are performed and evaluated. The results are discussed based on the probability of success of random PSO versus DPSO. Finally, a comparison of random PSO to DPSO is shown for the hull-form optimization of the DTMB 5415 model. In summary, test functions show the robustness of DPSO, which outperforms random PSO with odds of 30/1 for low-dimensional problems (indicatively N ≤ 30) and 5/1 for high-dimensional problems (N > 30). The hull-form SBDO (N = 11) shows how DPSO outperforms PSO with odds of 20/1. The use of DPSO in the SBDO context is therefore advised, especially if computationally expensive analyses are involved in the optimization. © 2018 International Center for Numerical Methods in Engineering. All rights reserved.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 12}
}

