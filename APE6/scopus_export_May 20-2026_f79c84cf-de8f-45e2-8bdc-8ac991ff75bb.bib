	pages = {},
	doi = {10.1109/UPCON66414.2025.11453745},
	url = {https://www.scopus.com/pages/publications/105036387825?origin=resultslist},
	abstract = {Salp Swarm Optimization (SSO) has attracted attention due to its simple structure and limited number of control parameters. However, when applied to high-dimensional problems or search spaces with strong inter-variable dependencies, the algorithm often experiences premature convergence and loss of diversity. To address this limitation, this work introduces Quantum-Entangled Salp Swarm Optimization (QESSO), an extended version of SSO that integrates quantum-inspired concepts, including Q-bit representation and entanglement-based interactions among decision variables. By allowing correlated updates between variables and incorporating a localized refinement strategy around the best solution, the proposed method enhances both exploration and exploitation capabilities. The performance of QESSO is assessed using the IEEE CEC 2017 benchmark suite, which includes unimodal, multimodal, hybrid, and composite test functions designed to emulate complex optimization landscapes. Comparative experiments against SSO, PSO, QPSO, and Differential Evolution (DE) indicate that QESSO consistently achieves improved convergence behavior, lower variance across runs, and better scalability as dimensionality increases. Although the evaluation in this study focuses on benchmark functions, the characteristics of these problems resemble those encountered in engineering design, control optimization, logistics planning, and other industrial applications. Direct validation on domain-specific industrial case studies is planned for future investigation. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

