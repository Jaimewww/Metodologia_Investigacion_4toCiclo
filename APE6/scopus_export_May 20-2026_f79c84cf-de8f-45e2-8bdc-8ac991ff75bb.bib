@ARTICLE{Gao20241179,
	author = {Gao, Nannan and Shi, Renhe and Tai, Xinhui and Ye, Nianhui},
	title = {Surrogate-Assisted Hybrid Searching Method for High-Dimensional Expensive Optimization Problems},
	year = {2024},
	journal = {Mechanisms and Machine Science},
