}

@ARTICLE{Liu2025,
	author = {Liu, Shuichang and Xue, Zhihao and Chen, Xin and Pan, Renhui and Zhang, Yong and Zhong, Zelin},
	title = {An Automatic Calibration Framework of Storm Water Management Model Based on KPCA-SSA-BPNN and its Application in Urban Stormwater Flood Simulation},
