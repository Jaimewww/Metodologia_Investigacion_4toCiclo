@CONFERENCE{Satish2025,
	author = {Satish, Hariprita and Katipally, Avighna Reddy and Jayan, Sarada},
	title = {Autonomous Vehicle Path Optimization Using a Hybrid Chaotic Pattern Search Algorithm: A Comparative Study with PSO},
