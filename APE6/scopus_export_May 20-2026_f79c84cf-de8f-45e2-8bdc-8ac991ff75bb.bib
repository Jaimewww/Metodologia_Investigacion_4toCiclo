@ARTICLE{Kanaker2026,
	author = {Kanaker, Hasan and Al Sayaydeh, Osama and Alhroob, Essam and Karim, Nader Abdel and Smadi, Sami and Asmak Ismail, Nurul Halimatul},
	title = {Novel Hybrid Nature-Inspired Metaheuristic Algorithm for Global and Engineering Design Optimization},
	year = {2026},
	journal = {Computers},
	volume = {15},
	number = {4},
	pages = {},
	doi = {10.3390/computers15040211},
	url = {https://www.scopus.com/pages/publications/105037070649?origin=resultslist},
	abstract = {Metaheuristic algorithms have become indispensable for solving high-dimensional, non-convex, and constrained optimization problems arising in science and engineering. However, no single method can simultaneously provide strong global exploration, accurate local exploitation, and robust performance across diverse problem classes. This paper proposes JADEFLO, a new hybrid nature-inspired metaheuristic that couples Adaptive Differential Evolution with Optional External Archive (JADE) and Frilled Lizard Optimization (FLO) in a two-stage search framework. In the first stage, JADE drives global exploration using p-best mutation, an external archive, and adaptive control of the mutation factor and crossover rate to maintain population diversity. In the second stage, FLO performs intensive local refinement by mimicking the hunting and tree-climbing behaviors of frilled lizards through dedicated exploration and exploitation moves. The resulting algorithm has linear time complexity with respect to the population size, dimensionality, and number of iterations. JADEFLO is evaluated on the IEEE CEC 2022 single-objective benchmark suite (F1–F12) and three constrained engineering design problems (Pressure Vessel, tension/compression spring, and speed reducer), using 30 independent runs and comparisons against more than thirty state-of-the-art metaheuristics, including GA, PSO, DE variants, GWO, WOA, MFO, and FLO. The results show that JADEFLO attains the best overall rank on the CEC functions, delivers faster convergence and higher accuracy on most test cases, and matches or improves the best-known designs with markedly reduced variance. These findings indicate that JADEFLO is a promising general-purpose optimizer and a flexible foundation for future extensions to multi-objective and large-scale optimization. © 2026 by the authors.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Asgharzadeh-Bonab2026,
	author = {Asgharzadeh-Bonab, Akbar and Bijanvand, Sajad and Laal Dehghani, Kasra},
	title = {Hybrid optimizer with adaptive operator for efficient high-dimensional constrained problems},
	year = {2026},
	journal = {Structures},
	volume = {83},
	pages = {},
	doi = {10.1016/j.istruc.2025.110784},
	url = {https://www.scopus.com/pages/publications/105034272329?origin=resultslist},
	abstract = {Optimization problems in engineering and applied sciences are often very complex, involving many variables and irregular search spaces, rendering traditional methods ineffective. To address these challenges, this paper introduces the Hybrid Optimizer with Adaptive Operator (HOAO), a four-stage hybrid metaheuristic framework designed for constrained continuous and discrete optimization problems. In HOAO, the search process begins with the Puma Optimizer, which provides rapid initial global exploration. Building on this, Particle Swarm Optimization is launched using the best solution identified by PO together with Latin Hypercube samples, and is further strengthened by a newly developed adaptive operator that integrates Lévy Flights, Chaotic Local Search, and Opposition-Based Learning. As the search progresses, HOAO leverages the historical global best to guide the optimization more effectively, ultimately leading to a final deterministic refinement performed by the Interior Point Method, which is initialized from the best feasible solution obtained in the preceding phases. By utilizing historical data to initialize and guide the search, HOAO mitigates issues like local entrapment and excessive evaluations, promoting efficient global convergence with limited tuning. HOAO was extensively evaluated on 50 benchmark functions and was compared against state-of-the-art algorithms including kernel-search variants, original metaheuristics, and their AOS-upgraded versions. Statistically significant superiority was observed, Friedman ranks placed HOAO first, and runtime analyses reported efficiency gains up to 99.7 % on selected high-dimensional tests. In structural applications HOAO produced the lightest feasible designs across 120, 200, and 582-bar truss problems, often requiring 10–22 % fewer function evaluations and exhibiting markedly lower variability than competing methods. HOAO stands out as a powerful framework for tackling complex real-world problems, with potential for future extensions to multi-objective optimization. © 2025 Published by Elsevier Ltd on behalf of Institution of Structural Engineers.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Zhang20233089,
	author = {Zhang, Youpeng and Wei, Zhijian and Yang, Ni and Zhang, Di},
	title = {Fault diagnosis method of S700K switch machine based on KPCA SVM; [基于 KPCA SVM 的 S700K 转辙机故障诊断方法]},
	year = {2023},
