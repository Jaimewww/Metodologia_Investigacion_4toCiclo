	url = {https://www.scopus.com/pages/publications/105009821075?origin=resultslist},
	abstract = {Accurately evaluating the ice melting rate of a thermal drill bit presents a significant challenge due to the complexities of calculating the heat losses during ice drilling. To address this, an ice melting model incorporating thermal efficiency was developed for a replicate thermal coring system. A series of experiments were conducted, and a multi-strategy Improved Snake Optimization (IMSO) algorithm was proposed to solve the equation governing the ice melting rate. The IMSO algorithm integrates four enhanced strategies to boost its global and local search capabilities, and avoid premature convergence, including a k-means clustering strategy, a leader-follower mechanism, an enhanced equilibrium solutions strategy, and a hybrid optimization strategy that integrates selection, crossover, and simulated annealing techniques. Performance evaluations conducted on Congress on Evolutionary Computation (CEC) 2017 benchmark functions demonstrated that IMSO outperforms other algorithms, such as Particle Swarm Optimization, Genetic Algorithm, Whale Optimization Algorithm, Sine Cosine Algorithm, and Snake Optimization, in adaptability and functionality. Further validation through five engineering cases studies confirmed IMSO's effectiveness in solving complex problems across diverse fields. Using the IMSO algorithm, the ice melting rates under various conditions were determined. Results indicated that the IMSO algorithm improved the goodness-of-fit of the thermal efficiency model from 0.713 to 0.889. Without thermal efficiency, the predicted ice melting rate is consistently much higher than the experimental melting rate, with maximum deviations of 53.22 %, 38.44 %, and 17.88 % under varying heating power, environmental temperature, and drilling pressure conditions, respectively. When the thermal efficiency derived from IMSO was considered, these errors were significantly reduced to 5.36 %, 12.64 %, and 2.47 %, respectively. © 2025 Elsevier Ltd},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2}
}

