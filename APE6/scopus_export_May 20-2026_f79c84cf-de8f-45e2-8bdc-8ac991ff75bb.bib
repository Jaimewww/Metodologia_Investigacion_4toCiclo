@ARTICLE{Abdalla2025,
	author = {Abdalla, Ramez and Agban, Nermine and Lüddeke, Christian and Sui, Dan and Jaeger, Philip},
	title = {Multi agent physics informed reinforcement learning for waterflooding optimization},
