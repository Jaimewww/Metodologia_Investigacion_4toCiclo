@ARTICLE{Nassar2012931,
	author = {Nassar, Khaled and Hosny, Ossama},
	title = {Solving the least-cost route cut and fill sequencing problem using particle swarm},
	year = {2012},
	journal = {Journal of Construction Engineering and Management},
	volume = {138},
	number = {8},
