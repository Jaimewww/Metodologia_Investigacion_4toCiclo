@ARTICLE{Liu2025,
	author = {Liu, Xuan and Tian, Mengnan and Wang, Xinduan},
	title = {Enhanced particle swarm algorithm with diversity-based adaptive predicted learning strategy for numerical optimization},
	year = {2025},
