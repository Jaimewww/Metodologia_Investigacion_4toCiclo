@ARTICLE{Jiang2024,
	author = {Jiang, Jianhua and Huang, Jiansheng and Wu, Jiaqi and Luo, Jinmeng and Yang, Xi and Li, Weihua},
	title = {DTSA: Dynamic Tree-Seed Algorithm with Velocity-Driven Seed Generation and Count-Based Adaptive Strategies},
