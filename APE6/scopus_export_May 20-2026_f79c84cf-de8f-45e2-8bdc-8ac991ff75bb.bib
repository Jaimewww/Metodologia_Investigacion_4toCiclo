@ARTICLE{Yao2026,
	author = {Yao, Rui and Wang, Yuye and Yu, Fei and Wu, Hongrun and Diao, Zhenya},
	title = {Dynamic Weighted Spherical Particle Swarm Optimization for UAV Path Planning in Complex Environments},
