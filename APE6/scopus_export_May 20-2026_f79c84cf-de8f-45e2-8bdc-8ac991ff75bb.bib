@ARTICLE{Maiti20251650,
	author = {Maiti, Binanda and Biswas, Saptadeep and Bera, Uttam Kumar and Deb, Madhujit and Jia, Heming and Saleem, Kashif and Migdady, Hazem and Smerat, Aseel and Abualigah, Laith},
	title = {A Chaotic Boost: The Chaotic Crayfish Optimization Algorithm for Superior Solution Quality},
	year = {2025},
