@ARTICLE{Lin2025274,
	author = {Lin, Guizhu and Lin, Shuwang and Lu, Weilin},
	title = {MECHANICAL MANUFACTURING PRODUCTION OPTIMIZATION MODEL BASED ON NEIGHBORHOOD SEARCH IMPROVED PSO ALGORITHM},
