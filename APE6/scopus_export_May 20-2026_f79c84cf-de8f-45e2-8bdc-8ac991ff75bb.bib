@ARTICLE{Atha2024,
	author = {Atha, Romio and Rajan, Abhishek and Mallick, Sourav},
	title = {An enhanced Equilibrium Optimizer for solving complex optimization problems},
	year = {2024},
	journal = {Information Sciences},
