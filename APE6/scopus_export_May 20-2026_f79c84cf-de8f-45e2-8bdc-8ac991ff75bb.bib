@ARTICLE{Dong202583717,
	author = {Dong, Jie and Wang, Lifu and Qiao, Shuhui and Wang, Peng and Tan, Xiuhui},
	title = {House Swallow Optimizer: A New Meta-Heuristic Algorithm and Its Application for DOA Estimation of Broadband Signal in Vector Hydrophone Array},
	year = {2025},
