@ARTICLE{Wang2026,
	author = {Wang, Chaodong and Hu, Die and Li, Zhongyu and An, Hongyang and Sun, Zhichao and Wu, Junjie and Yang, Jianyu},
	title = {A Configuration Optimization Method Based on Decoupled Recursive Strategy for Distributed UAV SAR 3D Imaging System},
	year = {2026},
	journal = {Remote Sensing},
	volume = {18},
	number = {4},
	pages = {},
	doi = {10.3390/rs18040625},
	url = {https://www.scopus.com/pages/publications/105031525997?origin=resultslist},
	abstract = {Highlights: What are the main findings? A configuration optimization model is established for distributed UAV SAR 3D imaging, jointly optimizing sensing performance and UAV compactness under practical constraints. A decoupled recursive strategy is proposed, decomposing the 3D problem into a continuous subproblem and a recursive procedure, thereby enhancing solution capability and efficiency. What are the implications of the main findings? We improve the 3D reconstruction capability of distributed UAV SAR systems under complex practical constraints. We reduce the meta-heuristic optimization dimensionality from 3D to 1D, accelerating processing speed while avoiding challenges from the highly fragmented feasible region to ensure robust global performance. Compared with conventional synthetic aperture radar (SAR) three-dimensional (3D) imaging systems, distributed unmanned aerial vehicle (UAV) SAR systems offer enhanced flexibility and single-pass capability, enabling rapid 3D imaging. Their performance, however, critically depends on the spatial arrangement of UAVs. Improper configurations result in grating lobes and increase the sidelobe level, thereby degrading elevation reconstruction. Additionally, the coordinated operation of distributed UAVs imposes spatial constraints such as safety separation. To address these challenges, this paper formulates the configuration design as a multi-constraint, multi-objective optimization problem that simultaneously considers both imaging performance and operational feasibility. Based on compressive sensing (CS) theory, the influence of configuration on sparse imaging is analyzed, and practical constraints are integrated, including 3D span limits, safety separation, and mainlobe avoidance. A joint optimization model is established to minimize the cumulative coherence of the sensing matrix while maximizing system spatial compactness. To efficiently solve this high-dimensional problem, a decoupled recursive strategy is proposed. In the first stage, a hybrid algorithm combining particle swarm optimization (PSO) and covariance matrix adaptation evolution strategy (CMA-ES) performs global optimization in the baseline domain. In the second stage, a compact configuration is constructed within the feasible region via analytical spatial recursion. Experimental results demonstrate that the proposed approach effectively reduces sensing matrix coherence and improves 3D reconstruction quality. © 2026 by the authors.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

